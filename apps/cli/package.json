{
  "name": "jiratown",
  "version": "0.1.7",
  "description": "CLI for creating and running local JiraTown apps.",
  "license": "MIT",
  "homepage": "https://github.com/penguinkang/jiratown#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/penguinkang/jiratown.git",
    "directory": "apps/cli"
  },
  "bugs": {
    "url": "https://github.com/penguinkang/jiratown/issues"
  },
  "type": "module",
  "files": [
    "dist",
    "docs",
    "templates",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "jiratown": "dist/index.js",
    "jt": "dist/index.js"
  },
  "scripts": {
    "jiratown": "tsx src/index.ts",
    "build": "tsc -p tsconfig.build.json && chmod +x dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@jiratown/shared": "^0.1.2",
    "tsx": "^4.19.2"
  },
  "devDependencies": {
    "@types/node": "^22.10.7",
    "typescript": "^5.7.3"
  }
}
